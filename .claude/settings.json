{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(flutter create*)",
      "Bash(flutter pub get*)",
      "Bash(flutter pub add*)",
      "Bash(flutter analyze*)",
      "Bash(flutter build*)",
      "Bash(flutter run*)",
      "Bash(flutter test*)",
      "Bash(flutter --version*)",
      "Bash(dart analyze*)",
      "Bash(dart format*)",
      "Bash(dart run*)",
      "Bash(dart --version*)",
      "Bash(mkdir -p assets/*)",
      "Bash(mkdir -p lib/*)",
      "Bash(mkdir -p design/*)",
      "Bash(mkdir -p production/*)",
      "Bash(touch *)",
      "Bash(python3 *simulate_rtp*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(sudo *)",
      "Bash(chmod 777*)",
      "Bash(*>.env*)",
      "Read(**/.env*)"
    ]
  }
}
